{
  "manifest_version": 3,
  "name": "Sunox Browser Bridge",
  "description": "Runs Suno generation challenges inside an existing Suno tab for the Sunox CLI.",
  "version": "0.1.2",
  "minimum_chrome_version": "120",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "https://suno.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://suno.com/*"],
      "js": ["page.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://suno.com/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
